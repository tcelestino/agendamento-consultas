{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "src",
    "vitest.config.*",
    "eslint.config.*",
    "__tests__",
    "src/repositories/.repository.interface.ts",
  ],
  "compilerOptions": {
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
  },
}
